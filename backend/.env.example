# Server
PORT=8080

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://haskelling:haskelling@localhost:5432/haskelling_dev
DB_POOL_SIZE=10

# Judge0
# Set JUDGE0_MOCK=true during local development to avoid consuming API quota.
# Get an API key at https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=your_judge0_api_key_here
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_MOCK=true

# Clerk (get these from your Clerk dashboard)
# Use the JWKS URL from your Clerk development instance for local/staging.
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# Rate limiting
RATE_LIMIT_PER_IP=20
RATE_LIMIT_PER_USER=10
