# Server
PORT=8080

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://haskelling:haskelling@localhost:5432/haskelling_dev
DB_POOL_SIZE=10

# Curriculum
# Path to the curriculum directory. Default is ../curriculum (relative to the backend dir).
CURRICULUM_DIR=../curriculum

# Judge0 (via RapidAPI)
# Set JUDGE0_MOCK=true during local development to avoid consuming API quota.
# Get an API key at https://rapidapi.com/judge0-official/api/judge0-ce
# RapidAPI requires both x-rapidapi-key and x-rapidapi-host headers on every request.
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
JUDGE0_MOCK=true

# Clerk (get these from your Clerk dashboard — Development instance keys for local dev)
# Both keys are required; the server will not start without them.
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Rate limiting
RATE_LIMIT_PER_IP=20
RATE_LIMIT_PER_USER=10

# Draft content
# Set to true locally to see chapters/exercises whose date_added is null (i.e. not yet published).
SHOW_DRAFT_CONTENT=false
